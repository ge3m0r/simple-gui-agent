# GUI Agent 环境变量示例
# 复制为 .env 并填写

# 阿里云 DashScope API Key（用于 Qwen-VL / Qwen3-VL）
DASHSCOPE_API_KEY=sk-xxx

# 若使用 OpenAI 或其它兼容端点，可设置：
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：默认 VLM 模型名
# GUI_AGENT_VLM_MODEL=qwen-vl-plus

# 可选：屏幕分辨率（与当前显示器一致可提高坐标准确性）
# GUI_AGENT_SCREEN_WIDTH=1920
# GUI_AGENT_SCREEN_HEIGHT=1080

# 可选：最大步数、步间延迟、历史长度
# GUI_AGENT_MAX_STEPS=30
# GUI_AGENT_STEP_DELAY=1.0
# GUI_AGENT_MAX_TRAJECTORY=3

# 可选：网格化动作空间（网格越密定位越准；默认 20x20，小按钮可试 24x24 或 30x30）
# GUI_AGENT_GRID_ROWS=20
# GUI_AGENT_GRID_COLS=20

# 可选：送 VLM 前截图预处理方式（grid=网格 | resize_only=仅缩放 | accessibility=无障碍树混合）
# GUI_AGENT_IMAGE_PREPROCESSOR=grid
# 无障碍树仅枚举前台窗口（true=更快、项少，false=全桌面约千项）
# GUI_AGENT_ACCESSIBILITY_FOREGROUND_ONLY=true
# 无障碍树是否仅在模型返回点击/双击等动作时才获取元素（true=按需获取、用 name 点击，false=每步都获取、用 element_id）
# 是否仅在模型返回点击类动作时再获取无障碍元素（true=按需获取、用 name 点击；false=每步都获取、传 element_id，默认 false）
# GUI_AGENT_ACCESSIBILITY_FETCH_ON_CLICK_ONLY=false
# 当预处理为 grid 时，是否在图上绘制网格线
# GUI_AGENT_ANNOTATE_GRID=true

# 输入英文/URL/命令前是否自动切换输入法（留空=不自动，由模型规划）。设为 "ctrl,space" 或 "win,space" 时，TYPING 纯英文前会先发该快捷键
# GUI_AGENT_TYPING_IME_SWITCH_FOR_ASCII=

# 调试：第一步保存送 VLM 的截图到 debug_screenshot_0.png（便于核对坐标准确性）
# GUI_AGENT_DEBUG_SAVE_SCREENSHOT=true
